;;------------------------------------------------------------
;; PART 4: Logic functions
;;------------------------------------------------------------

(defun aia-parse-codes (input / norm codes entry)
  ;; Returns list of discipline-map entries matching input string.
  ;; Handles individual codes (A, M, P) and combos (MEP, AMEP).
  (setq norm  (strcase input)
        codes nil)
  (foreach entry *aia-discipline-map*
    (if (wcmatch norm (strcat "*" (car entry) "*"))
      (setq codes (append codes (list entry)))
    )
  )
  codes
)

(defun create-layers-for-codes (entries)
  (foreach entry entries
    (princ (strcat "\n\n[" (car entry) "] " (caddr entry) "..."))
    (foreach row (eval (cadr entry))
      (apply 'make-layer row)
    )
  )
)

(defun delete-layers-for-codes (entries)
  (foreach entry entries
    (princ (strcat "\n\n[" (car entry) "] " (caddr entry) "..."))
    (foreach row (eval (cadr entry))
      (apply 'delete-layer row)
    )
  )
)

;;------------------------------------------------------------
;; PART 5: Commands
;;------------------------------------------------------------

(defun c:LayAIAcreateAll ( / *error* lay-count del-count del-skip)
  (defun *error* (msg)
    (if (not (member msg '("Function cancelled" "quit / exit abort")))
      (princ (strcat "\nError: " msg)))
    (princ))
  (aia-header "CREATE")
  (create-layers-for-codes *aia-discipline-map*)
  (aia-footer "CREATE")
)

(defun c:LayAIAcreateOnly ( / *error* lay-count del-count del-skip input codes)
  (defun *error* (msg)
    (if (not (member msg '("Function cancelled" "quit / exit abort")))
      (princ (strcat "\nError: " msg)))
    (princ))
  (setq input (getstring "\nEnter discipline codes (e.g. MEP, AMEP, A, EP...): "))
  (setq codes (aia-parse-codes input))
  (aia-header "CREATE")
  (if codes
    (create-layers-for-codes codes)
    (progn
      (princ (strcat "\n  WARNING: No valid discipline codes found in \"" input "\""))
      (princ "\n  Valid codes: A B C E F G H I L M P Q R S T V X")
      (princ "\n  Named combos: MEP  AMEP")
    )
  )
  (aia-footer "CREATE")
)

(defun c:LayAIAdeleteAll ( / *error* lay-count del-count del-skip)
  (defun *error* (msg)
    (if (not (member msg '("Function cancelled" "quit / exit abort")))
      (princ (strcat "\nError: " msg)))
    (princ))
  (aia-header "DELETE")
  (delete-layers-for-codes *aia-discipline-map*)
  (aia-footer "DELETE")
)

(defun c:LayAIAdeleteOnly ( / *error* lay-count del-count del-skip input codes)
  (defun *error* (msg)
    (if (not (member msg '("Function cancelled" "quit / exit abort")))
      (princ (strcat "\nError: " msg)))
    (princ))
  (setq input (getstring "\nEnter discipline codes to delete (e.g. MEP, A, EP...): "))
  (setq codes (aia-parse-codes input))
  (aia-header "DELETE")
  (if codes
    (delete-layers-for-codes codes)
    (progn
      (princ (strcat "\n  WARNING: No valid discipline codes found in \"" input "\""))
      (princ "\n  Valid codes: A B C E F G H I L M P Q R S T V X")
      (princ "\n  Named combos: MEP  AMEP")
    )
  )
  (aia-footer "DELETE")
)
