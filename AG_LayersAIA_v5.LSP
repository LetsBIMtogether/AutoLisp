(vl-load-com)

;;------------------------------------------------------------
;; PART 1: Low level helpers
;;------------------------------------------------------------

(defun load-ltype (lt)
  (if (and lt
           (not (equal lt "Continuous"))
           (not (tblsearch "LTYPE" lt)))
    (vl-cmdf "-LINETYPE" "LOAD" lt "acad.lin" "")
  )
)

(defun make-layer (name color ltype desc)
  (if (not (tblsearch "LAYER" name))
    (progn
      (load-ltype ltype)
      (entmake
        (list
          '(0 . "LAYER")
          '(100 . "AcDbSymbolTableRecord")
          '(100 . "AcDbLayerTableRecord")
          (cons 2  name)
          '(70 . 0)
          (cons 62 color)
          (cons 6  ltype)
          '(290 . 1)
          '(370 . -3)
        )
      )
      (if (and desc (not (equal desc "")))
        (vla-put-description
          (vla-item
            (vla-get-layers (vla-get-activedocument (vlax-get-acad-object)))
            name)
          desc)
      )
      (setq lay-count (1+ lay-count))
    )
  )
)

(defun delete-layer (name color ltype desc / lyr)
  ;; Signature mirrors make-layer so (apply 'delete-layer row) works on
  ;; the same data rows. color / ltype / desc are accepted but unused.
  (if (tblsearch "LAYER" name)
    (if (equal (strcase name) (strcase (getvar "CLAYER")))
      (setq del-skip (1+ del-skip))
      (progn
        (setq lyr
          (vla-item
            (vla-get-layers (vla-get-activedocument (vlax-get-acad-object)))
            name))
        (vl-catch-all-apply 'vla-delete (list lyr))
        (if (not (tblsearch "LAYER" name))
          (setq del-count (1+ del-count))
          (setq del-skip  (1+ del-skip))
        )
      )
    )
  )
)

;;------------------------------------------------------------
;; PART 2: UI helpers
;;------------------------------------------------------------

(defun aia-header (mode)
  (setq lay-count 0
        del-count 0
        del-skip  0)
  (setvar "CMDECHO" 0)
  (princ "\n====================================================")
  (princ "\n  AG Layers AIA v5  - AIA/NCS v5 Layer Generator")
  (princ "\n====================================================")
)

(defun aia-footer (mode)
  (setvar "CMDECHO" 1)
  (princ "\n")
  (princ "\n====================================================")
  (princ (strcat "\n  AG Layers AIA v5 - " mode " COMPLETE"))
  (princ "\n====================================================")
  (if (equal mode "CREATE")
    (progn
      (princ (strcat "\n  LAYERS CREATED : " (itoa lay-count)))
      (princ "\n  Run LAYER command to review all layers.")
      (princ "\n  Note: Existing layers were skipped.")
    )
  )
  (if (equal mode "DELETE")
    (progn
      (princ (strcat "\n  LAYERS DELETED : " (itoa del-count)))
      (princ (strcat "\n  LAYERS SKIPPED : " (itoa del-skip)
                     " (current layer or layer in use)"))
      (princ "\n  Run LAYER command to review remaining layers.")
    )
  )
  (princ "\n====================================================\n")
  (princ)
)

